# ============================================================
# TEMPLATE DE VARIABLES DE ENTORNO — Frontend
# ============================================================
# Copia este archivo a .env y ajusta los valores locales.
# El archivo .env NO se sube a git (está en .gitignore).
# ============================================================

# URL base de la API (Express + PostgreSQL)
# Desarrollo: http://localhost:5000/api
# Producción: https://tu-backend.railway.app/api
VITE_API_URL=http://localhost:5000/api

# URL pública del sitio (para Open Graph y canonical URLs)
# Desarrollo: http://localhost:5173
# Producción: https://sojotrendy.com
VITE_SITE_URL=http://localhost:5173
