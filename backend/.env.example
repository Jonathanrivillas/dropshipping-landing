# =========================================
# VARIABLES DE ENTORNO — Backend (Railway)
# =========================================

# Base de datos PostgreSQL
# Railway la inyecta automáticamente si usas el addon de PostgreSQL
DATABASE_URL="postgresql://user:password@host:5432/dbname?schema=public"

# MercadoPago
MP_ACCESS_TOKEN="APP_USR-..."

# Webhook de MercadoPago (obtener en el dashboard de MP → Webhooks)
MP_WEBHOOK_SECRET="tu_clave_secreta_del_webhook"

# URL del frontend (para CORS y links en emails)
# Ej: https://sojotrendy.vercel.app
FRONTEND_URL="https://tu-frontend.vercel.app"

# JWT para el panel admin
JWT_SECRET="cambia_esto_por_un_string_largo_y_aleatorio"

# Credenciales del admin
ADMIN_EMAIL="admin@sojotrendy.com"
# Generar hash con: node -e "const b = require('bcryptjs'); b.hash('tuPassword', 10).then(console.log)"
ADMIN_PASSWORD_HASH="$2b$10$..."

# Email (Resend) — opcional, los emails se omiten si no está configurado
RESEND_API_KEY="re_..."
EMAIL_FROM="pedidos@sojotrendy.com"

# Puerto (Railway lo inyecta automáticamente)
PORT=5000
