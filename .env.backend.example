# ============================================================
# TEMPLATE DE VARIABLES DE ENTORNO — Backend
# ============================================================
# Copia este archivo a backend/.env y ajusta los valores.
# El archivo backend/.env NO se sube a git.
# ============================================================

# ── ENTORNO ──────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ── BASE DE DATOS ────────────────────────────────────────────
# PostgreSQL connection string
# Desarrollo local (Docker): postgresql://johndoe:randompassword@localhost:5432/mydb
# Producción (Railway): se genera automáticamente al crear la BD
DATABASE_URL=postgresql://johndoe:randompassword@localhost:5432/mydb?schema=public

# ── CORS ─────────────────────────────────────────────────────
# URL del frontend (para permitir peticiones cross-origin)
# Desarrollo: http://localhost:5173
# Producción: https://sojotrendy.com
FRONTEND_URL=http://localhost:5173

ALLOWED_ORIGINS=http://localhost:5174,http://localhost:3000

# ── PASARELA DE PAGO ────────────────────────────────────────
# MercadoPago
MP_ACCESS_TOKEN=APP_USR-your_access_token_here

# Secret de validación de webhooks de MercadoPago.
# Se genera en el panel de MP al configurar la URL del webhook:
# https://www.mercadopago.com.co/developers/panel/app/{app_id}/webhooks
# En desarrollo puede dejarse vacío (la firma no se verifica).
MP_WEBHOOK_SECRET=

# ── AUTENTICACIÓN ADMIN ──────────────────────────────────────
# Secreto para firmar JWTs (usa un string largo y aleatorio en producción)
JWT_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio

# Email del administrador
ADMIN_EMAIL=admin@sojotrendy.com

# Bcrypt hash de la contraseña del admin.
# Para generar: node -e "const b=require('bcryptjs');b.hash('TuContraseña',10).then(console.log)"
# Hash por defecto de "admin123" — CAMBIAR EN PRODUCCIÓN
ADMIN_PASSWORD_HASH=$2b$10$UBORvXlsFR/syOaAiFjwouj6noh6sOkD2TphVLKtY/D/H/Wf6JAj2

# MercadoPago
MERCADOPAGO_ACCESS_TOKEN=APP_USR-your-access-token
MERCADOPAGO_PUBLIC_KEY=APP_USR-your-public-key

# PayU (Colombia)
PAYU_API_KEY=your-payu-api-key
PAYU_MERCHANT_ID=your-merchant-id
PAYU_ACCOUNT_ID=your-account-id

# ── EMAIL (futuro) ───────────────────────────────────────────
# SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=notificaciones@sojotrendy.com
SMTP_PASS=your-app-specific-password

# ── EMAIL (Resend) ───────────────────────────────────────────
# Obtén tu API key gratis en https://resend.com (3000 emails/mes gratis)
# Si no se configura, los emails se omiten silenciosamente.
RESEND_API_KEY=re_your-resend-api-key

# Dirección remitente — debe ser de un dominio verificado en Resend
# En desarrollo puedes usar onboarding@resend.dev (sin verificar dominio)
EMAIL_FROM=pedidos@sojotrendy.com

# ── ALMACENAMIENTO DE ARCHIVOS ───────────────────────────────
# AWS S3
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=sojotrendy-products

# Cloudinary (alternativa)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ── REDIS (caché - opcional) ─────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=your-redis-password

# ── RATE LIMITING ────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000  # 15 minutos en ms
RATE_LIMIT_MAX_REQUESTS=100   # Máximo de requests por ventana

# Login rate limit (más restrictivo)
LOGIN_RATE_LIMIT_WINDOW_MS=900000  # 15 minutos
LOGIN_RATE_LIMIT_MAX_REQUESTS=5     # Máximo 5 intentos de login

# ── LOGGING ──────────────────────────────────────────────────
LOG_LEVEL=info  # error | warn | info | debug
LOG_FORMAT=json  # json | pretty

# ── MONITOREO ────────────────────────────────────────────────
# Sentry (error tracking)
SENTRY_DSN=https://your-sentry-dsn@sentry.io/your-project-id

# New Relic (APM)
NEW_RELIC_LICENSE_KEY=your-license-key
NEW_RELIC_APP_NAME=Sojo Trendy API

# ── OTROS ────────────────────────────────────────────────────
# URL del frontend (para CORS y redirects)
FRONTEND_URL=http://localhost:5174

# URL pública del API (para webhooks)
API_URL=http://localhost:3001

# Admin email (para notificaciones críticas)
ADMIN_EMAIL=admin@sojotrendy.com

# Timezone
TZ=America/Bogota

# ============================================================
# EJEMPLO PARA PRODUCCIÓN
# ============================================================
# NODE_ENV=production
# PORT=3001
# DATABASE_URL=postgresql://user:pass@db.example.com:5432/sojotrendy?sslmode=require
# JWT_SECRET=production-secret-key-very-long-and-random
# ALLOWED_ORIGINS=https://sojotrendy.com,https://www.sojotrendy.com
# FRONTEND_URL=https://sojotrendy.com
# API_URL=https://api.sojotrendy.com
# ============================================================
